# ===== Servidor =====
PORT=3333
NODE_ENV=development

# CORS (origens separadas por virgula). Vazio = libera todas (util no dev do Expo).
ALLOWED_ORIGINS=

# ===== Banco de dados =====
# Se DATABASE_URL estiver preenchido, usa PostgreSQL (ex.: Neon).
# Se ficar vazio, cai no SQLite local (backend/data.sqlite) -> roda sem nenhum setup.
DATABASE_URL=
# Exemplo Neon:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ===== JWT =====
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
