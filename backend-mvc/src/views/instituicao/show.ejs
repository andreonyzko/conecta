<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2><%= instituicao.nome %></h2>
    <p class="text-muted mb-0"><i class="bi bi-file-text me-1"></i>CNPJ: <%= instituicao.cnpj %></p>
    <% if (instituicao.telefone) { %><p class="text-muted"><i class="bi bi-telephone me-1"></i><%= instituicao.telefone %></p><% } %>
    <% if (instituicao.endereco) { %><p class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= instituicao.endereco %></p><% } %>
  </div>
  <% if (user && user.perfilId === instituicao.id) { %>
    <a href="/instituicao/<%= instituicao.id %>/edit" class="btn btn-outline-secondary">Editar Perfil</a>
  <% } %>
</div>

<h5 class="mb-3">Chamadas Publicadas (<%= chamadas.length %>)</h5>
<% if (chamadas.length === 0) { %>
  <p class="text-muted">Nenhuma chamada publicada ainda.</p>
<% } %>
<div class="row g-3">
<% chamadas.forEach(c => { %>
  <div class="col-md-6">
    <div class="card h-100 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <h6><a href="/chamadas/<%= c.id %>"><%= c.titulo %></a></h6>
          <span class="badge badge-status-<%= c.status %>"><%= c.status %></span>
        </div>
        <p class="text-muted small mb-0"><%= c.dataInicio %> até <%= c.dataFim %></p>
      </div>
    </div>
  </div>
<% }) %>
</div>
<%- include('../partials/footer') %>
