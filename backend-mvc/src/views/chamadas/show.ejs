<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h2><%= chamada.titulo %></h2>
    <p class="text-muted"><a href="/instituicao/<%= chamada.instituicaoId %>"><i class="bi bi-building me-1"></i><%= chamada.instituicao?.nome %></a></p>
  </div>
  <span class="badge fs-6 badge-status-<%= chamada.status %>"><%= chamada.status %></span>
</div>

<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <p class="mb-1"><i class="bi bi-calendar me-1"></i><strong>Período:</strong> <%= chamada.dataInicio %> até <%= chamada.dataFim %></p>
    <p class="mb-0"><%= chamada.descricao %></p>
  </div>
</div>

<h5 class="mb-3">Itens da Chamada</h5>
<div class="row g-2 mb-4">
<% itensStatus.forEach(item => { %>
  <div class="col-md-6">
    <div class="card">
      <div class="card-body p-3">
        <div class="d-flex justify-content-between">
          <strong><%= item.produto %></strong>
          <% if (item.atendido) { %>
            <span class="badge bg-success">Atendido</span>
          <% } else { %>
            <span class="text-muted small"><%= item.quantidadeAtendida %>/<%= item.quantidade %> atendido</span>
          <% } %>
        </div>
        <p class="text-muted small mb-1"><%= item.categoria %> · <%= item.frequencia %></p>
        <p class="small mb-1"><%= item.quantidade %> <%= item.unidade %></p>
        <div class="progress" style="height:6px">
          <div class="progress-bar bg-success" style="width:<%= Math.min(100, Math.round(item.quantidadeAtendida/item.quantidade*100)) %>%"></div>
        </div>
      </div>
    </div>
  </div>
<% }) %>
</div>

<% if (user && user.role === 'instituicao' && user.perfilId === chamada.instituicaoId && chamada.status === 'ativa') { %>
  <h5 class="mb-3">Propostas Recebidas (<%= propostas.length %>)</h5>
  <% if (propostas.length === 0) { %>
    <p class="text-muted">Nenhuma proposta recebida ainda.</p>
  <% } %>
  <div class="table-responsive mb-4">
    <table class="table table-hover">
      <thead><tr><th>Agricultor</th><th>Valor Total</th><th>Status</th><th>Entrega</th><th>Ações</th></tr></thead>
      <tbody>
      <% propostas.forEach(p => { %>
        <tr>
          <td><a href="/agricultor/<%= p.agricultorId %>"><%= p.agricultor?.nome %></a></td>
          <td>R$ <%= p.valorTotal.toFixed(2) %></td>
          <td><span class="badge bg-<%= p.status === 'aceita' ? 'success' : p.status === 'rejeitada' ? 'danger' : 'warning text-dark' %>"><%= p.status %></span></td>
          <td><%= p.realizaEntrega ? 'Sim' : 'Não' %></td>
          <td>
            <a href="/propostas/<%= p.id %>" class="btn btn-sm btn-outline-secondary">Ver</a>
            <% if (p.status === 'pendente') { %>
              <form method="POST" action="/propostas/<%= p.id %>/aceitar" class="d-inline">
                <button class="btn btn-sm btn-success">Aceitar</button>
              </form>
              <form method="POST" action="/propostas/<%= p.id %>/rejeitar" class="d-inline">
                <button class="btn btn-sm btn-outline-danger">Rejeitar</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <div class="d-flex gap-2">
    <a href="/chamadas/<%= chamada.id %>/edit" class="btn btn-outline-secondary">Editar</a>
    <% if (totalmenteAtendida && propostas.some(p => p.status === 'aceita')) { %>
      <a href="/chamadas/<%= chamada.id %>/encerrar" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Encerrar Chamada</a>
    <% } %>
    <form method="POST" action="/chamadas/<%= chamada.id %>/cancelar" onsubmit="return confirm('Cancelar esta chamada?')">
      <button class="btn btn-outline-danger">Cancelar Chamada</button>
    </form>
  </div>
<% } %>

<% if (user && user.role === 'agricultor' && chamada.status === 'ativa') { %>
  <% if (!totalmenteAtendida) { %>
    <a href="/chamadas/<%= chamada.id %>/propostas/new" class="btn btn-success mt-3">
      <i class="bi bi-send me-1"></i>Enviar Proposta
    </a>
  <% } else { %>
    <div class="alert alert-info mt-3">Todos os itens desta chamada já foram atendidos.</div>
  <% } %>
<% } %>
<%- include('../partials/footer') %>
