<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<h2 class="mb-4">Editar Perfil</h2>
<div class="row g-4">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-body p-4">
        <h5 class="mb-3">Dados Pessoais</h5>
        <form method="POST" action="/agricultor/<%= agricultor.id %>?_method=PUT">
          <div class="mb-3"><label class="form-label">Nome</label><input type="text" name="nome" class="form-control" value="<%= agricultor.nome %>" required /></div>
          <div class="mb-3"><label class="form-label">Telefone</label><input type="text" name="telefone" class="form-control" value="<%= agricultor.telefone || '' %>" /></div>
          <div class="row mb-3">
            <div class="col"><label class="form-label">Município</label><input type="text" name="municipio" class="form-control" value="<%= agricultor.municipio || '' %>" /></div>
            <div class="col"><label class="form-label">Estado</label><input type="text" name="estado" class="form-control" value="<%= agricultor.estado || '' %>" maxlength="2" placeholder="PR" /></div>
          </div>
          <div class="mb-3"><label class="form-label">CAF (Cadastro Agricultor Familiar)</label><input type="text" name="caf" class="form-control" value="<%= agricultor.caf || '' %>" /></div>
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="realizaEntrega" id="realizaEntrega" <%= agricultor.realizaEntrega ? 'checked' : '' %> />
              <label class="form-check-label" for="realizaEntrega">Realizo entrega dos produtos</label>
            </div>
          </div>
          <button type="submit" class="btn btn-success">Salvar</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h5 class="mb-3">Produtos que Ofereço</h5>
        <% agricultor.produtos?.forEach(p => { %>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span><%= p.nome %></span>
            <form method="POST" action="/agricultor/<%= agricultor.id %>/produtos/<%= p.id %>?_method=DELETE" class="d-inline" onsubmit="return confirm('Remover produto?')">
              <button class="btn btn-sm btn-outline-danger py-0">&times;</button>
            </form>
          </div>
        <% }) %>
        <% if (!agricultor.produtos || agricultor.produtos.length === 0) { %>
          <p class="text-muted small">Nenhum produto adicionado.</p>
        <% } %>
        <hr />
        <form method="POST" action="/agricultor/<%= agricultor.id %>/produtos">
          <div class="mb-2"><input type="text" name="nome" class="form-control" placeholder="Nome do produto" required /></div>
          <div class="mb-2"><input type="text" name="categoria" class="form-control" placeholder="Categoria (ex: Hortaliças)" /></div>
          <div class="row g-1 mb-2">
            <div class="col"><input type="number" name="capacidadeMensal" class="form-control" placeholder="Qtd/mês" min="0" step="0.01" /></div>
            <div class="col"><input type="text" name="unidade" class="form-control" placeholder="kg" /></div>
          </div>
          <button class="btn btn-outline-success btn-sm w-100" type="submit"><i class="bi bi-plus me-1"></i>Adicionar</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
