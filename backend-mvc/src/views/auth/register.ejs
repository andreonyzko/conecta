<%- include('../partials/header') %>
<%- include('../partials/flash') %>
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h4 class="card-title mb-4"><i class="bi bi-person-plus-fill me-2"></i>Criar conta</h4>
        <form method="POST" action="/register" id="registerForm">
          <div class="mb-3">
            <label class="form-label">Tipo de conta</label>
            <select name="role" id="roleSelect" class="form-select" required onchange="toggleFields()">
              <option value="">Selecione...</option>
              <option value="agricultor">Agricultor</option>
              <option value="instituicao">Instituição</option>
            </select>
          </div>
          <div class="mb-3"><label class="form-label">Nome</label><input type="text" name="nome" class="form-control" required /></div>
          <div class="mb-3"><label class="form-label">E-mail</label><input type="email" name="email" class="form-control" required /></div>
          <div class="mb-3"><label class="form-label">Senha</label><input type="password" name="senha" class="form-control" minlength="6" required /></div>
          <div class="mb-3"><label class="form-label">Telefone</label><input type="text" name="telefone" class="form-control" required /></div>

          <div id="fieldAgricultor" style="display:none">
            <div class="mb-3"><label class="form-label">CPF</label><input type="text" name="cpfCnpj" class="form-control" /></div>
            <div class="mb-3"><label class="form-label">CAF (opcional)</label><input type="text" name="caf" class="form-control" /></div>
          </div>
          <div id="fieldInstituicao" style="display:none">
            <div class="mb-3"><label class="form-label">CNPJ</label><input type="text" name="cpfCnpj" class="form-control" /></div>
            <div class="mb-3"><label class="form-label">Número de alunos</label><input type="number" name="numeroAlunos" class="form-control" min="0" /></div>
          </div>

          <button type="submit" class="btn btn-success w-100">Cadastrar</button>
        </form>
        <p class="mt-3 text-center text-muted">Já tem conta? <a href="/login">Entrar</a></p>
      </div>
    </div>
  </div>
</div>
<script>
function toggleFields() {
  const role = document.getElementById('roleSelect').value;
  document.getElementById('fieldAgricultor').style.display = role === 'agricultor' ? '' : 'none';
  document.getElementById('fieldInstituicao').style.display = role === 'instituicao' ? '' : 'none';
}
</script>
<%- include('../partials/footer') %>
